# Application settings
APP_NAME=Legal Consultation Platform
DEBUG=true

# Database
# SQLite (default, no extra setup needed)
DATABASE_URL=sqlite:///./legal_platform.db

# PostgreSQL (optional)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/legal_platform

# JWT settings
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# File upload
UPLOAD_DIR=uploads
